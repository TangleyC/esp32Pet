{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DeskPet",
  "version": "0.1.0",
  "identifier": "com.deskpet.mvp",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "DeskPet Control Center",
        "width": 820,
        "height": 760,
        "minWidth": 360,
        "minHeight": 620
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
